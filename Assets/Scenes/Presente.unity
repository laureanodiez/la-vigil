  - setName: DialogoGuia1
    speaker:
    - "Gu\xEDa1"
    dialogueWords:
    - "Ah, \xBFya pudiste hablar con la secretaria en la Comisi\xF3n Directiva? Es
      abajo, a la izquierda de donde arrancamos la visita!"
    portrait:
